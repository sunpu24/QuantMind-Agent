# =========================
# QuantMind Agent Runtime
# =========================
QUANTMIND_ENV=development
QUANTMIND_OUTPUT_LANGUAGE=zh-CN

# =========================
# Data Provider
# 可选: auto / mock / akshare / tushare / alpha_vantage
# auto: A 股自动走 tushare，美股自动走 Alpha Vantage
# =========================
QUANTMIND_DATA_PROVIDER=auto

# Tushare
# 获取 token 后可设置：QUANTMIND_DATA_PROVIDER=tushare
# 注意：不要提交真实 token 到 Git
TUSHARE_TOKEN=your_tushare_token_here

# News Provider
# 可选: auto / mock / akshare / alpha_vantage
# auto: A 股新闻走 AkShare，美股新闻走 Alpha Vantage
QUANTMIND_NEWS_PROVIDER=auto
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
ALPHA_VANTAGE_TIMEOUT=15

# AkShare 通常不需要 API Key，但这里预留代理/开关
AKSHARE_ENABLED=true
AKSHARE_TIMEOUT=15

# =========================
# LLM Provider
# 可选: mock / openai / deepseek / qwen / zhipu / ollama
# 第一版默认 mock，后续可切换真实 LLM
# =========================
QUANTMIND_LLM_PROVIDER=mock
QUANTMIND_LLM_MODEL=deepseek-chat
QUANTMIND_LLM_BASE_URL=https://api.deepseek.com
QUANTMIND_LLM_API_KEY=
QUANTMIND_LLM_TIMEOUT=30

# OpenAI-compatible providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=

# =========================
# Risk Settings
# =========================
QUANTMIND_DEFAULT_POSITION_SIZE=0.3
QUANTMIND_MAX_POSITION_SIZE=0.5
QUANTMIND_STOP_LOSS_PCT=0.05
QUANTMIND_TAKE_PROFIT_PCT=0.1
